diff --git a/r9clark.f b/r9clark.f
index 5244da5..e78baac 100644
--- a/r9clark.f
+++ b/r9clark.f
@@ -368,9 +368,25 @@ C-----Get topwood cubic volumes
       
 !...  get log lengths, dibs
         CALL R9LOGS(SAWHT, PLPHT, STUMP, MINLEN, MAXLEN, TRIM,
-     &       LOGLEN,LOGDIA,NOLOGP,NOLOGS,TLOGS,COEFFS,ERRFLG,BOLHT) 
-     
+     &       LOGLEN,LOGDIA,NOLOGP,NOLOGS,TLOGS,COEFFS,ERRFLG,BOLHT)
+
         IF(ERRFLG .NE. 0) THEN
+C  ERRFLG=12 means the stem needs >20 logs for the fixed 20-log arrays.
+C  That invalidates only the board-foot LOG detail, NOT the cubic taper
+C  integrals (vol 1/4/7) already computed by r9cuft. Preserve the cubic
+C  volume and report 0 board-foot rather than discarding a valid volume
+C  as 0 (fixes the extreme-height 0-cuft summary bug).
+          IF(ERRFLG .EQ. 12) THEN
+            VOL(2) = 0.0
+            READ(VOLEQ(1:1),'(I1)') REGN
+            IF(REGN.EQ.9) CALL r9cor(vol,logVol,spp,iProd)
+            IF(vol(1).GT.0.0) vol(1)=nint(vol(1)*10.0)/10.0
+            IF(vol(4).GT.0.0) vol(4)=nint(vol(4)*10.0)/10.0
+            IF(vol(7).GT.0.0) vol(7)=nint(vol(7)*10.0)/10.0
+            VOL(2) = 0.0
+            ERRFLG = 0
+            RETURN
+          ENDIF
           DO 525, I=1,15
              VOL(I) = 0.0
   525     CONTINUE
