# Simulation output — FVS writes these next to the keyword file / in the cwd.
*.db
*.sum
*.out
*.tls
*.trl
*.chp
*.sng
*.key.bak

# Julia build artifacts (Manifest.toml IS tracked for reproducibility)
*.so
*.dylib
*.dll
LocalPreferences.toml

# Editor / OS
.DS_Store
*.swp
test/harness/scenarios/*.tre
tmp/
.claude/worktrees/

# stray FFE DSNOUT database (default name, no extension)
__DSNOUT__

# committed reference outputs in examples/ (override the *.sum ignore above)
!examples/**/*.fvsjl.sum
!examples/**/*.fvssn.sum
# committed live-oracle golden sums for the all-species coverage tests
!test/fixtures/**/*.live.sum
deps/libfvsmath.*

# durable local FIA sweep coverage DB (survives sessions/container restart; not git-tracked)
data/*.db
data/*.db-wal
data/*.db-shm

# persistent sweep working dir (scratch + redundant master ledger; results are in data/*.db)
.sweep_work/
